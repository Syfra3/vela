{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vela.local/schemas/organization-map-v1.json",
  "title": "Vela Organization Map V1",
  "description": "Documentation-oriented organization topology artifact kept separate from repo-local .vela/graph retrieval data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "scope",
    "nodes",
    "edges"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    },
    "views": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/view"
      },
      "uniqueItems": true
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization"
      ],
      "properties": {
        "organization": {
          "type": "string",
          "minLength": 1
        },
        "workspace": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenance": {
      "type": "string",
      "enum": [
        "declared",
        "iac",
        "repo_metadata",
        "inferred",
        "manual_override"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "nodeType": {
      "type": "string",
      "enum": [
        "organization",
        "workspace",
        "repository",
        "service",
        "resource",
        "document"
      ]
    },
    "resourceKind": {
      "type": "string",
      "enum": [
        "database",
        "queue",
        "bucket",
        "topic",
        "cache",
        "secret_store",
        "dns",
        "api_gateway",
        "function",
        "object_store",
        "vendor_api",
        "kubernetes_cluster",
        "namespace",
        "network",
        "other"
      ]
    },
    "edgeType": {
      "type": "string",
      "enum": [
        "contains",
        "owns",
        "deploys_to",
        "uses",
        "calls",
        "publishes_to",
        "consumes_from",
        "exposes",
        "documents",
        "bridges"
      ]
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "name",
        "provenance",
        "confidence",
        "source_ref",
        "observed_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "$ref": "#/$defs/nodeType"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "labels": {
          "$ref": "#/$defs/stringList"
        },
        "tags": {
          "$ref": "#/$defs/stringList"
        },
        "resource_kind": {
          "$ref": "#/$defs/resourceKind"
        },
        "external_ref": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "resource"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "resource_kind"
            ]
          },
          "else": {
            "not": {
              "required": [
                "resource_kind"
              ]
            }
          }
        }
      ]
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "from",
        "to",
        "provenance",
        "confidence",
        "source_ref",
        "observed_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "$ref": "#/$defs/edgeType"
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "directional": {
          "type": "boolean",
          "default": true
        },
        "labels": {
          "$ref": "#/$defs/stringList"
        },
        "external_ref": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "Workspace View",
            "Resource View",
            "Bridge Relations"
          ]
        },
        "description": {
          "type": "string"
        },
        "default_node_types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nodeType"
          },
          "uniqueItems": true
        },
        "default_edge_types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edgeType"
          },
          "uniqueItems": true
        },
        "hide_low_confidence": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
